# =========================================================================
# Sentinel Server · 环境变量样板
# 复制为 .env 后填写真实值，.env 不会进 git
# =========================================================================

# ── Gateway (Go) ────────────────────────────────────────────────────────
GATEWAY_ADDR=:8080
GATEWAY_LOG_LEVEL=info               # debug | info | warn | error
GATEWAY_ENV=development              # development | staging | production

# ── JWT ─────────────────────────────────────────────────────────────────
# ⚠️ 强校验：启动时会拒绝以下情况
#   1) 长度 < 32 字节
#   2) 含占位片段（change-me / please-change / your-secret / replace-me / placeholder）
#   3) ACCESS 与 REFRESH 相同
# 生成命令：openssl rand -hex 32（每个 secret 独立生成一次）
JWT_ACCESS_SECRET=please-change-using-openssl-rand-hex-32
JWT_REFRESH_SECRET=please-change-using-openssl-rand-hex-32-different
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h                 # 7 天

# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
DATABASE_URL=postgres://sentinel:sentinel@postgres:5432/sentinel?sslmode=disable

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── MinIO / S3 ──────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=sentinel
MINIO_SECRET_KEY=sentinel123
MINIO_USE_SSL=false
MINIO_BUCKET_RECORDINGS=sentinel-recordings
MINIO_BUCKET_MODELS=sentinel-models
MINIO_BUCKET_CREDENTIALS=sentinel-credentials

# ── AI Service ──────────────────────────────────────────────────────────
AI_BASE_URL=http://ai:8090
AI_TIMEOUT=30s

# =========================================================================
# AI 引擎 provider 开关
# =========================================================================

# ── Whisper provider：local / openai ────────────────────────────────────
WHISPER_PROVIDER=local

# 本地 (faster-whisper)
#   WHISPER_MODEL_PATH 留空时用官方预训练 size；
#   填了路径或 HF repo id 则加载自训练 / 微调权重（CTranslate2 格式）。
WHISPER_MODEL_PATH=
WHISPER_MODEL_SIZE=large-v3          # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu                   # cpu | cuda
WHISPER_COMPUTE_TYPE=int8            # int8 | float16 | float32
WHISPER_LANGUAGE=zh
WHISPER_VAD_FILTER=true
WHISPER_CACHE_DIR=/app/models/whisper-cache

# OpenAI Audio API
WHISPER_OPENAI_MODEL=whisper-1       # whisper-1 | gpt-4o-mini-transcribe | gpt-4o-transcribe

# ── LLM provider：qwen / openai ─────────────────────────────────────────
LLM_PROVIDER=qwen

# DashScope (千问)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
QWEN_MODEL=qwen-max
QWEN_TEMPERATURE=0.2
QWEN_TOP_P=0.9
QWEN_MAX_TOKENS=1024

# OpenAI (Chat + Audio 共用 KEY / BASE_URL)
#   OPENAI_BASE_URL 留空 → 官方 https://api.openai.com/v1
#   可指向 Azure OpenAI、第三方兼容代理、自部署 vLLM 等。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_TOP_P=0.9
OPENAI_MAX_TOKENS=1024

# 通用系统提示词（两种 LLM provider 都会用）
LLM_SYSTEM_PROMPT=你是一名反诈通话分析专家。请判定通话内容是否构成电信诈骗，并按 5 类标签 + 置信度输出 JSON。

# ── CORS ────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate Limit ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
